<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="TaskPaneApp">
  <Id>A26676E8-B2EA-49CC-B340-6BFE9BF26DEC</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>BIBRAC</ProviderName>
  <DefaultLocale>fr-FR</DefaultLocale>
  <DisplayName DefaultValue="BIBRAC Add-in"/>
  <Description DefaultValue="Fonctions personnalisées BIBRAC pour Excel"/>
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://mafiases971.github.io/bibrac-addin/"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <Runtimes>
          <Runtime resid="Shared.Url" lifetime="long" type="general"/>
        </Runtimes>
        <AllFormFactors>
          <ExtensionPoint xsi:type="CustomFunctions">
            <Script>
              <SourceLocation resid="Functions.Script.Url"/>
            </Script>
            <Page>
              <SourceLocation resid="Shared.Url"/>
            </Page>
            <Metadata>
              <SourceLocation resid="Functions.Metadata.Url"/>
            </Metadata>
            <Namespace resid="Functions.Namespace"/>
          </ExtensionPoint>
        </AllFormFactors>
      </Host>
    </Hosts>
    <Resources>
      <bt:Urls>
        <bt:Url id="Shared.Url" DefaultValue="https://mafiases971.github.io/bibrac-addin/"/>
        <bt:Url id="Functions.Script.Url" DefaultValue="https://mafiases971.github.io/bibrac-addin/functions.js"/>
        <bt:Url id="Functions.Metadata.Url" DefaultValue="https://mafiases971.github.io/bibrac-addin/functions.json"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="Functions.Namespace" DefaultValue="BIBRAC"/>
      </bt:ShortStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
